---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import ArticleCard from '../components/ArticleCard.astro';
import CTA from '../components/CTA.astro';
import SupervisorBox from '../components/SupervisorBox.astro';
import Icon from '../components/icons/Icon.astro';
import { SITE_TITLE, SITE_DESCRIPTION, UNIVERSITIES } from '../consts';

const articles = (await getCollection('articles', ({ data }) => !data.draft))
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const featured = articles.slice(0, 6);

// 大学ごとの記事数を集計
const univStats = UNIVERSITIES.map((u) => ({
	...u,
	count: articles.filter((a) => a.id.startsWith(`${u.slug}/`)).length,
}));
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="hero-bg">
					<div class="hero-blob hero-blob-1"></div>
					<div class="hero-blob hero-blob-2"></div>
				</div>
				<div class="hero-inner">
					<div class="hero-pill">
						<Icon name="sparkles" size={14} stroke="#fde68a" />
						<span>新卒採用10年・1,000人以上評価×総合型選抜指導100名以上</span>
					</div>
					<h1>「合格して終わり」にしない<br />志望理由書添削</h1>
					<p class="lead">
						大学のアドミッションポリシーから逆算した「刺さる志望理由」を、<br class="pc-only" />
						合格者多数の講師と一緒に作ります。
					</p>
					<div class="hero-cta">
						<a href="/" class="btn-primary" data-ga-event="cta_click" data-ga-label="hero">
							無料診断を受ける
							<Icon name="arrow-right" size={18} />
						</a>
						<a href="/articles" class="btn-secondary" data-ga-event="nav_click" data-ga-label="hero_articles">記事を読む</a>
					</div>
					<p class="hero-note">3分で完了｜LINEで結果が届く｜無料添削サンプル付き</p>
				</div>
			</section>

			<section class="universities">
				<div class="section-header">
					<h2>大学から選ぶ</h2>
					<p class="section-sub">志望大学のハブページから、学部別・入試方式別の記事に進めます</p>
				</div>
				<div class="univ-grid">
					{univStats.map((u) => (
						<a
							href={`/articles/${u.slug}/`}
							class="univ-card"
							style={`--accent: ${u.color}; --accent-bg: ${u.bg};`}
						>
							<div class="univ-name">
								<Icon name="graduation" size={18} />
								<span>{u.name}</span>
							</div>
							<div class="univ-meta">
								<span class="univ-count">{u.count}記事</span>
								<Icon name="chevron-right" size={16} />
							</div>
						</a>
					))}
				</div>
			</section>

			<section class="features">
				<div class="features-grid">
					<div class="feature">
						<div class="feature-icon">
							<Icon name="pencil" size={22} stroke="#1a4d8f" />
						</div>
						<h3>採用担当者の視点で添削</h3>
						<p>大手企業の新卒採用を10年担当した講師が、入社後も通用する志望動機を一緒に作ります。</p>
					</div>
					<div class="feature">
						<div class="feature-icon">
							<Icon name="star" size={22} stroke="#1a4d8f" />
						</div>
						<h3>100名以上の指導実績</h3>
						<p>大手総合型選抜塾で4年間にわたり、早慶上智MARCHを中心に多数の合格者を輩出。</p>
					</div>
					<div class="feature">
						<div class="feature-icon">
							<Icon name="compass" size={22} stroke="#1a4d8f" />
						</div>
						<h3>大学AP起点の設計</h3>
						<p>各大学・学部のアドミッションポリシーから逆算し、刺さる志望理由を設計します。</p>
					</div>
				</div>
			</section>

			<section class="articles-section">
				<div class="section-header inline">
					<h2>新着記事</h2>
					<a href="/articles" class="see-all">
						<span>すべて見る</span>
						<Icon name="arrow-right" size={14} />
					</a>
				</div>
				<div class="grid">
					{featured.map((a) => (
						<ArticleCard
							href={`/articles/${a.id}/`}
							slug={a.id}
							title={a.data.title}
							description={a.data.description}
							category={a.data.category}
							date={a.data.date}
						/>
					))}
				</div>
			</section>

			<CTA />

			<section class="supervisor-section">
				<div class="section-header">
					<h2>監修者について</h2>
				</div>
				<SupervisorBox variant="full" />
			</section>
		</main>
		<Footer />

		<style>
			main {
				max-width: 1200px;
				margin: 0 auto;
				padding: 0 1rem;
			}
			.hero {
				position: relative;
				background: linear-gradient(135deg, #1a4d8f 0%, #0f3a6f 100%);
				padding: 4.5rem 1rem 5rem;
				margin: 0 -1rem 3rem;
				text-align: center;
				border-radius: 0 0 32px 32px;
				color: white;
				overflow: hidden;
			}
			.hero-bg {
				position: absolute;
				inset: 0;
				pointer-events: none;
				overflow: hidden;
			}
			.hero-blob {
				position: absolute;
				border-radius: 50%;
				filter: blur(60px);
				opacity: 0.4;
			}
			.hero-blob-1 {
				width: 380px;
				height: 380px;
				background: #ef4444;
				top: -120px;
				right: -80px;
			}
			.hero-blob-2 {
				width: 320px;
				height: 320px;
				background: #2563eb;
				bottom: -120px;
				left: -60px;
				opacity: 0.5;
			}
			.hero-inner {
				position: relative;
				max-width: 760px;
				margin: 0 auto;
				z-index: 1;
			}
			.hero-pill {
				display: inline-flex;
				align-items: center;
				gap: 0.4rem;
				background: rgba(253, 230, 138, 0.15);
				border: 1px solid rgba(253, 230, 138, 0.35);
				color: #fde68a;
				font-size: 0.78rem;
				font-weight: 600;
				padding: 0.35rem 0.95rem;
				border-radius: 999px;
				margin-bottom: 1.4rem;
			}
			.hero h1 {
				font-size: 2.5rem;
				color: white;
				margin: 0 0 1.1rem;
				line-height: 1.45;
				letter-spacing: -0.01em;
			}
			.lead {
				color: #dbeafe;
				font-size: 1.08rem;
				line-height: 1.85;
				margin: 0 0 2rem;
			}
			.hero-cta {
				display: flex;
				gap: 1rem;
				justify-content: center;
				flex-wrap: wrap;
				margin-bottom: 1rem;
			}
			.btn-primary, .btn-secondary {
				padding: 0.95rem 2rem;
				border-radius: 999px;
				font-weight: 700;
				text-decoration: none;
				font-size: 1rem;
				display: inline-flex;
				align-items: center;
				gap: 0.45rem;
				transition: transform 0.15s, background 0.15s, box-shadow 0.15s;
			}
			.btn-primary {
				background: #ef4444;
				color: white;
				box-shadow: 0 8px 22px rgba(239, 68, 68, 0.4);
			}
			.btn-primary:hover {
				background: #dc2626;
				transform: translateY(-2px);
				box-shadow: 0 12px 28px rgba(239, 68, 68, 0.5);
			}
			.btn-secondary {
				background: rgba(255, 255, 255, 0.1);
				color: white;
				border: 1.5px solid rgba(255, 255, 255, 0.4);
				backdrop-filter: blur(8px);
			}
			.btn-secondary:hover {
				background: rgba(255, 255, 255, 0.2);
				transform: translateY(-2px);
			}
			.hero-note {
				font-size: 0.82rem;
				color: #93c5fd;
				margin: 0;
			}

			.section-header {
				margin-bottom: 1.5rem;
			}
			.section-header.inline {
				display: flex;
				align-items: baseline;
				justify-content: space-between;
				flex-wrap: wrap;
				gap: 0.5rem;
			}
			.section-header h2 {
				margin: 0;
				font-size: 1.55rem;
				color: #0f172a;
				padding-left: 0.85rem;
				border-left: 4px solid #1a4d8f;
				letter-spacing: -0.005em;
			}
			.section-sub {
				margin: 0.6rem 0 0;
				color: #64748b;
				font-size: 0.92rem;
				padding-left: 0.85rem;
			}
			.see-all {
				font-size: 0.9rem;
				color: #1a4d8f;
				text-decoration: none;
				font-weight: 600;
				display: inline-flex;
				align-items: center;
				gap: 0.25rem;
				transition: gap 0.15s;
			}
			.see-all:hover {
				gap: 0.45rem;
				text-decoration: underline;
			}

			.universities {
				margin-bottom: 4rem;
			}
			.univ-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
				gap: 0.85rem;
			}
			.univ-card {
				display: flex;
				flex-direction: column;
				justify-content: space-between;
				background: white;
				border: 1px solid #e5e7eb;
				border-left: 4px solid var(--accent);
				border-radius: 12px;
				padding: 1.1rem 1.2rem;
				text-decoration: none;
				color: inherit;
				transition: transform 0.15s, box-shadow 0.15s, border-color 0.15s;
				min-height: 96px;
			}
			.univ-card:hover {
				transform: translateY(-3px);
				box-shadow: 0 12px 24px rgba(15, 23, 42, 0.08);
				border-color: var(--accent);
				background: var(--accent-bg);
			}
			.univ-name {
				display: flex;
				align-items: center;
				gap: 0.5rem;
				color: var(--accent);
				font-weight: 700;
				font-size: 1.02rem;
			}
			.univ-meta {
				display: flex;
				align-items: center;
				justify-content: space-between;
				margin-top: 0.6rem;
			}
			.univ-count {
				font-size: 0.78rem;
				color: #64748b;
				font-weight: 600;
			}
			.univ-card .univ-meta :global(svg) {
				color: var(--accent);
			}

			.features {
				margin-bottom: 4rem;
			}
			.features-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
				gap: 1.5rem;
			}
			.feature {
				background: white;
				border: 1px solid #e5e7eb;
				border-radius: 14px;
				padding: 1.6rem;
				position: relative;
				transition: transform 0.15s, box-shadow 0.15s;
			}
			.feature:hover {
				transform: translateY(-2px);
				box-shadow: 0 10px 24px rgba(15, 23, 42, 0.06);
			}
			.feature-icon {
				width: 44px;
				height: 44px;
				background: #eff6ff;
				border-radius: 10px;
				display: flex;
				align-items: center;
				justify-content: center;
				margin-bottom: 1rem;
			}
			.feature h3 {
				margin: 0 0 0.5rem;
				color: #0f172a;
				font-size: 1.12rem;
				letter-spacing: -0.005em;
			}
			.feature p {
				font-size: 0.9rem;
				line-height: 1.75;
				color: #475569;
				margin: 0;
			}

			.articles-section {
				margin-bottom: 3rem;
			}
			.grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
				gap: 1rem;
			}

			.supervisor-section {
				margin-bottom: 3rem;
			}

			.pc-only {
				display: inline;
			}
			@media (max-width: 720px) {
				.hero {
					padding: 3rem 1rem 3.5rem;
				}
				.hero h1 {
					font-size: 1.85rem;
					line-height: 1.5;
				}
				.lead {
					font-size: 0.98rem;
				}
				.btn-primary, .btn-secondary {
					padding: 0.85rem 1.6rem;
					font-size: 0.95rem;
				}
				.pc-only {
					display: none;
				}
				.section-header h2 {
					font-size: 1.3rem;
				}
				.univ-grid {
					grid-template-columns: repeat(2, 1fr);
					gap: 0.65rem;
				}
				.univ-card {
					padding: 0.9rem 1rem;
					min-height: 80px;
				}
				.univ-name {
					font-size: 0.92rem;
				}
			}
		</style>
	</body>
</html>
