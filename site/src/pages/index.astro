---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import ArticleCard from '../components/ArticleCard.astro';
import CTA from '../components/CTA.astro';
import SupervisorBox from '../components/SupervisorBox.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const articles = (await getCollection('articles', ({ data }) => !data.draft))
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const featured = articles.slice(0, 6);
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="hero-inner">
					<h1>「合格して終わり」にしない<br />志望理由書添削</h1>
					<p class="lead">
						採用人事10年×総合型選抜指導100名以上の講師が、<br />
						あなたの志望理由書を企業が将来求める人材像から逆算して添削します。
					</p>
					<div class="hero-cta">
						<a href="/contact" class="btn-primary">無料診断を受ける</a>
						<a href="/articles" class="btn-secondary">記事を読む</a>
					</div>
				</div>
			</section>

			<section class="features">
				<div class="features-grid">
					<div class="feature">
						<div class="feature-num">01</div>
						<h3>採用人事の視点で添削</h3>
						<p>大手企業の新卒採用を10年担当した講師が、入社後も通用する志望動機を一緒に作ります。</p>
					</div>
					<div class="feature">
						<div class="feature-num">02</div>
						<h3>100名以上の指導実績</h3>
						<p>大手総合型選抜塾で4年間にわたり、早慶上智MARCHを中心に多数の合格者を輩出。</p>
					</div>
					<div class="feature">
						<div class="feature-num">03</div>
						<h3>大学AP起点の設計</h3>
						<p>各大学・学部のアドミッションポリシーから逆算し、刺さる志望理由を設計します。</p>
					</div>
				</div>
			</section>

			<section class="articles-section">
				<div class="section-header">
					<h2>新着記事</h2>
					<a href="/articles" class="see-all">すべて見る →</a>
				</div>
				<div class="grid">
					{featured.map((a) => (
						<ArticleCard
							href={`/articles/${a.id}/`}
							title={a.data.title}
							description={a.data.description}
							category={a.data.category}
							date={a.data.date}
						/>
					))}
				</div>
			</section>

			<CTA />

			<section class="supervisor-section">
				<h2>監修者について</h2>
				<SupervisorBox variant="full" />
			</section>
		</main>
		<Footer />

		<style>
			main {
				max-width: 1100px;
				margin: 0 auto;
				padding: 0 1rem;
			}
			.hero {
				background: linear-gradient(135deg, #f0f7ff 0%, #e0ecff 100%);
				padding: 4rem 1rem;
				margin: 0 -1rem 3rem;
				text-align: center;
				border-radius: 0 0 24px 24px;
			}
			.hero-inner {
				max-width: 760px;
				margin: 0 auto;
			}
			.hero h1 {
				font-size: 2.25rem;
				color: #0f172a;
				margin: 0 0 1rem;
				line-height: 1.5;
			}
			.lead {
				color: #334155;
				font-size: 1.05rem;
				line-height: 1.8;
				margin: 0 0 2rem;
			}
			.hero-cta {
				display: flex;
				gap: 1rem;
				justify-content: center;
				flex-wrap: wrap;
			}
			.btn-primary, .btn-secondary {
				padding: 0.875rem 2rem;
				border-radius: 8px;
				font-weight: 700;
				text-decoration: none;
				font-size: 1rem;
			}
			.btn-primary {
				background: #ef4444;
				color: white;
			}
			.btn-primary:hover {
				background: #dc2626;
			}
			.btn-secondary {
				background: white;
				color: #1a4d8f;
				border: 2px solid #1a4d8f;
			}
			.btn-secondary:hover {
				background: #f1f5f9;
			}
			.features {
				margin-bottom: 4rem;
			}
			.features-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
				gap: 1.5rem;
			}
			.feature {
				background: white;
				border: 1px solid #e5e7eb;
				border-radius: 12px;
				padding: 1.5rem;
				position: relative;
			}
			.feature-num {
				color: #1a4d8f;
				font-weight: 700;
				font-size: 0.85rem;
				margin-bottom: 0.5rem;
			}
			.feature h3 {
				margin: 0 0 0.5rem;
				color: #0f172a;
				font-size: 1.1rem;
			}
			.feature p {
				font-size: 0.9rem;
				line-height: 1.7;
				color: #475569;
				margin: 0;
			}
			.articles-section {
				margin-bottom: 3rem;
			}
			.section-header {
				display: flex;
				align-items: center;
				justify-content: space-between;
				margin-bottom: 1.25rem;
			}
			.section-header h2 {
				margin: 0;
				font-size: 1.4rem;
				color: #0f172a;
				padding-left: 0.75rem;
				border-left: 4px solid #1a4d8f;
			}
			.see-all {
				font-size: 0.9rem;
				color: #1a4d8f;
				text-decoration: none;
				font-weight: 600;
			}
			.see-all:hover {
				text-decoration: underline;
			}
			.grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
				gap: 1rem;
			}
			.supervisor-section {
				margin-bottom: 3rem;
			}
			.supervisor-section h2 {
				font-size: 1.4rem;
				color: #0f172a;
				margin: 0 0 1rem;
				padding-left: 0.75rem;
				border-left: 4px solid #1a4d8f;
			}
			@media (max-width: 720px) {
				.hero h1 {
					font-size: 1.75rem;
				}
			}
		</style>
	</body>
</html>
