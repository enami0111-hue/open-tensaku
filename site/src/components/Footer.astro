---
import { SITE_TITLE } from '../consts';
const year = new Date().getFullYear();
---

<footer>
	<div class="footer-inner">
		<div class="footer-brand">
			<a href="/"><img src="/brand/logo-full.png" alt={SITE_TITLE} width="140" height="28" /></a>
		</div>
		<div class="footer-links">
			<a href="/articles">記事一覧</a>
			<a href="/terms">利用規約</a>
			<a href="/privacy">プライバシーポリシー</a>
			<a href="/">無料添削</a>
		</div>
		<div class="footer-copy">© {year} {SITE_TITLE}</div>
	</div>
</footer>

<style>
	footer {
		border-top: 1px solid #e5e7eb;
		padding: 28px 24px;
		font-size: 12px;
		color: #94a3b8;
		background: white;
		margin-top: 4rem;
	}
	.footer-inner {
		max-width: 1200px;
		margin: 0 auto;
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: center;
		gap: 20px;
	}
	.footer-brand img {
		height: 28px;
		width: auto;
		display: block;
	}
	.footer-links {
		display: flex;
		gap: 20px;
		justify-content: center;
		flex-wrap: wrap;
	}
	.footer-links a {
		color: #64748b;
		text-decoration: none;
		font-weight: 500;
		font-size: 0.82rem;
		transition: color 0.15s;
	}
	.footer-links a:hover { color: #1a4d8f; }
	.footer-copy {
		text-align: right;
		color: #94a3b8;
		font-size: 0.78rem;
	}
	@media (max-width: 720px) {
		.footer-inner {
			grid-template-columns: 1fr;
			text-align: center;
			gap: 12px;
		}
		.footer-brand img { margin: 0 auto; }
		.footer-copy { text-align: center; }
	}
</style>
