---
import FormattedDate from './FormattedDate.astro';
import { getUnivFromSlug } from '../consts';

interface Props {
	href: string;
	title: string;
	description: string;
	category: string;
	date: Date;
	slug?: string;
	heroImage?: string;
	isNew?: boolean;
}
const { href, title, description, category, date, slug, heroImage, isNew = false } = Astro.props;

const slugForUniv = slug ?? href.replace(/^\/articles\//, '').replace(/\/$/, '');
const univ = getUnivFromSlug(slugForUniv);
const accent = univ?.color ?? '#1a4d8f';
const accentBg = univ?.bg ?? '#eff6ff';
---

<a class:list={['card', { 'has-thumb': !!heroImage }]} href={href} style={`--accent: ${accent}; --accent-bg: ${accentBg};`}>
	{heroImage && (
		<div class="thumb">
			<img src={heroImage} alt={title} loading="lazy" />
		</div>
	)}
	<div class="body">
		<div class="tags">
			{univ && <span class="univ-chip">{univ.short}</span>}
			<span class="category">{category}</span>
			{isNew && <span class="new-badge new-badge-inline">NEW</span>}
		</div>
		<h3>{title}</h3>
		<p>{description}</p>
		<div class="meta">
			<FormattedDate date={date} />
		</div>
	</div>
</a>

<style>
	.card {
		display: block;
		background: white;
		border: 1px solid #e5e7eb;
		border-left: 4px solid var(--accent);
		border-radius: 12px;
		padding: 1.25rem;
		text-decoration: none;
		color: inherit;
		transition: transform 0.15s, box-shadow 0.15s, border-color 0.15s;
		position: relative;
		overflow: hidden;
	}
	.card:hover {
		transform: translateY(-2px);
		box-shadow: 0 10px 24px rgba(15, 23, 42, 0.08);
		border-color: var(--accent);
		border-left-color: var(--accent);
	}
	/* サムネありカードはpadding 0 にして画像をフル幅表示 */
	.card.has-thumb {
		padding: 0;
		border-left-width: 0;
		border-top: 3px solid var(--accent);
	}
	.thumb {
		width: 100%;
		aspect-ratio: 16 / 9;
		overflow: hidden;
		background: #f1f5f9;
		position: relative;
	}
	.new-badge {
		background: #ef4444;
		color: #fff;
		font-size: 0.65rem;
		font-weight: 800;
		padding: 0.15rem 0.45rem;
		border-radius: 4px;
		letter-spacing: 0.05em;
		margin-left: auto;
	}
	.thumb img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		transition: transform 0.3s;
	}
	.card:hover .thumb img {
		transform: scale(1.03);
	}
	.body {
		padding: 1rem 1.25rem 1.25rem;
	}
	/* サムネなし時はbodyがカード直下 */
	.card:not(.has-thumb) .body {
		padding: 0;
	}
	.tags {
		display: flex;
		gap: 0.4rem;
		flex-wrap: wrap;
		margin-bottom: 0.7rem;
	}
	.univ-chip {
		display: inline-block;
		background: var(--accent-bg);
		color: var(--accent);
		font-size: 0.72rem;
		font-weight: 700;
		padding: 0.18rem 0.55rem;
		border-radius: 4px;
		letter-spacing: 0.02em;
	}
	.category {
		display: inline-block;
		background: #f1f5f9;
		color: #475569;
		font-size: 0.72rem;
		font-weight: 600;
		padding: 0.18rem 0.55rem;
		border-radius: 4px;
	}
	h3 {
		margin: 0 0 0.5rem;
		font-size: 1.05rem;
		line-height: 1.55;
		color: #0f172a;
		letter-spacing: -0.005em;
	}
	p {
		font-size: 0.88rem;
		line-height: 1.65;
		color: #475569;
		margin: 0 0 0.75rem;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	.meta {
		font-size: 0.78rem;
		color: #94a3b8;
	}
</style>
