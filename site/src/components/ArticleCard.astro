---
import FormattedDate from './FormattedDate.astro';

interface Props {
	href: string;
	title: string;
	description: string;
	category: string;
	date: Date;
}
const { href, title, description, category, date } = Astro.props;
---

<a class="card" href={href}>
	<span class="category">{category}</span>
	<h3>{title}</h3>
	<p>{description}</p>
	<div class="meta">
		<FormattedDate date={date} />
	</div>
</a>

<style>
	.card {
		display: block;
		background: white;
		border: 1px solid #e5e7eb;
		border-radius: 12px;
		padding: 1.25rem;
		text-decoration: none;
		color: inherit;
		transition: transform 0.15s, box-shadow 0.15s, border-color 0.15s;
	}
	.card:hover {
		transform: translateY(-2px);
		box-shadow: 0 8px 16px rgba(0, 0, 0, 0.08);
		border-color: #1a4d8f;
	}
	.category {
		display: inline-block;
		background: #eff6ff;
		color: #1a4d8f;
		font-size: 0.75rem;
		font-weight: 600;
		padding: 0.2rem 0.6rem;
		border-radius: 4px;
		margin-bottom: 0.75rem;
	}
	h3 {
		margin: 0 0 0.5rem;
		font-size: 1.1rem;
		line-height: 1.5;
		color: #0f172a;
	}
	p {
		font-size: 0.9rem;
		line-height: 1.6;
		color: #475569;
		margin: 0 0 0.75rem;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	.meta {
		font-size: 0.8rem;
		color: #94a3b8;
	}
</style>
