---
import { SITE_TITLE } from '../consts';
---

<header>
	<nav class="header-inner">
		<a class="logo" href="/" aria-label={SITE_TITLE}>
			<img src="/brand/logo-full.png" alt={SITE_TITLE} width="180" height="44" />
		</a>
		<div class="header-nav">
			<a href="/articles">記事一覧</a>
		</div>
		<a href="/" class="header-cta">
			<span>無料で添削する</span>
		</a>
	</nav>
</header>

<style>
	header {
		background: #ffffff;
		border-bottom: 1px solid #e5e7eb;
		position: sticky;
		top: 0;
		z-index: 100;
	}
	.header-inner {
		display: flex;
		align-items: center;
		gap: 1.5rem;
		padding: 0 1.5rem;
		height: 64px;
		max-width: 1200px;
		margin: 0 auto;
	}
	.logo {
		display: flex;
		align-items: center;
		text-decoration: none;
		flex-shrink: 0;
		margin-right: auto;
	}
	.logo img {
		height: 40px;
		width: auto;
		display: block;
	}
	.header-nav {
		display: flex;
		align-items: stretch;
		gap: 0;
		height: 100%;
	}
	.header-nav a {
		display: inline-flex;
		align-items: center;
		padding: 0 1.25rem;
		color: #1f2937;
		text-decoration: none;
		font-size: 1rem;
		font-weight: 700;
		white-space: nowrap;
		position: relative;
		transition: color 0.15s;
	}
	.header-nav a::after {
		content: '';
		position: absolute;
		bottom: 0;
		left: 0.75rem;
		right: 0.75rem;
		height: 2px;
		background: #1a3f8f;
		border-radius: 2px 2px 0 0;
		transform: scaleX(0);
		transition: transform 0.18s;
	}
	.header-nav a:hover { color: #1a3f8f; }
	.header-nav a:hover::after { transform: scaleX(0.6); }
	.header-nav a.active { color: #1a3f8f; font-weight: 700; }
	.header-nav a.active::after { transform: scaleX(1); }
	.header-cta {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		background: #ef4444;
		color: white;
		padding: 0.5rem 1.1rem;
		border-radius: 999px;
		font-weight: 700;
		font-size: 0.875rem;
		text-decoration: none;
		white-space: nowrap;
		flex-shrink: 0;
		transition: background 0.15s, transform 0.12s, box-shadow 0.12s;
		box-shadow: 0 2px 8px rgba(239, 68, 68, 0.3);
	}
	.header-cta:hover {
		background: #dc2626;
		transform: translateY(-1px);
		box-shadow: 0 4px 14px rgba(239, 68, 68, 0.4);
	}
	@media (max-width: 720px) {
		.header-inner { padding: 0 1rem; height: 56px; }
		.header-nav { display: none; }
		.header-cta { display: none; }
		.logo img { height: 34px; }
	}
</style>
