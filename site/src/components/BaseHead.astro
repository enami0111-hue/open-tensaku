---
import '../styles/global.css';
import { SITE_TITLE, SITE_DESCRIPTION, SITE_OG_IMAGE, TWITTER_HANDLE } from '../consts';

interface Props {
	title: string;
	description?: string;
	image?: string;
	type?: 'website' | 'article';
	publishedTime?: Date;
	modifiedTime?: Date;
	keywords?: string[];
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const {
	title,
	description = SITE_DESCRIPTION,
	image = SITE_OG_IMAGE,
	type = 'website',
	publishedTime,
	modifiedTime,
	keywords,
} = Astro.props;

const ogImageUrl = new URL(image, Astro.site).toString();
const fullTitle = title === SITE_TITLE ? title : `${title} | ${SITE_TITLE}`;
---

<!-- Google Analytics 4 -->
{import.meta.env.PUBLIC_GA4_ID && (
  <>
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${import.meta.env.PUBLIC_GA4_ID}`}></script>
    <script define:vars={{ ga4Id: import.meta.env.PUBLIC_GA4_ID }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', ga4Id, { send_page_view: true });

      // CTA クリックイベント（data-ga-event 属性がある要素を自動追跡）
      document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('[data-ga-event]').forEach(function (el) {
          el.addEventListener('click', function () {
            gtag('event', el.dataset.gaEvent, {
              event_category: el.dataset.gaCategory || 'cta',
              event_label:    el.dataset.gaLabel   || '',
            });
          });
        });
      });
    </script>
  </>
)}

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta name="theme-color" content="#1B468C" />
<link rel="icon" type="image/png" sizes="32x32" href="/brand/logo-mark-32.png" />
<link rel="icon" type="image/png" sizes="180x180" href="/brand/logo-mark-180.png" />
<link rel="icon" type="image/png" sizes="512x512" href="/brand/logo-mark-512.png" />
<link rel="apple-touch-icon" sizes="180x180" href="/brand/logo-mark-180.png" />
<link rel="icon" href="/favicon.ico" />
<link rel="sitemap" href="/sitemap-index.xml" />
<meta name="generator" content={Astro.generator} />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{fullTitle}</title>
<meta name="title" content={fullTitle} />
<meta name="description" content={description} />
{keywords && keywords.length > 0 && <meta name="keywords" content={keywords.join(',')} />}

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:site_name" content={SITE_TITLE} />
<meta property="og:locale" content="ja_JP" />
{publishedTime && <meta property="article:published_time" content={publishedTime.toISOString()} />}
{modifiedTime && <meta property="article:modified_time" content={modifiedTime.toISOString()} />}

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={fullTitle} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={ogImageUrl} />
<meta property="twitter:site" content={TWITTER_HANDLE} />
