---
import { CTA } from '../consts';

type Props = {
	variant?: 'mid' | 'bottom';
	sourceOnly?: boolean;
};

const { variant = 'bottom', sourceOnly = false } = Astro.props;
const isMid = variant === 'mid';
const buttonLabel = '無料で添削を試す';
const gaLabel = isMid ? 'article_mid' : 'article_bottom';
---

<a
	href={CTA.buttonHref}
	class="article-bottom-cta"
	aria-label={buttonLabel}
	data-ga-event="cta_click"
	data-ga-label={gaLabel}
	data-mid-source={sourceOnly ? 'true' : undefined}
	hidden={sourceOnly}
>
	<div class="speed-mark" aria-hidden="true">
		<div class="clock">
			<span class="num">1</span>
			<span class="unit">min</span>
		</div>
		<span class="spark spark-1"></span>
		<span class="spark spark-2"></span>
		<span class="spark spark-3"></span>
	</div>

	<div class="copy">
		<h3>
			{isMid ? (
				<>
					<span class="lead">志望理由書の<em>改善点は？</em></span>
					<span class="result">1分で結果がわかる。</span>
				</>
			) : (
				<>
					<span class="lead">下書きを<em>無料で添削。</em></span>
					<span class="result">改善点がすぐわかる。</span>
				</>
			)}
		</h3>
		<div class="chips" aria-label="サービスの特徴">
			<span><i></i>完全無料</span>
			<span><i></i>登録不要</span>
		</div>
	</div>

	<div class="action">
		<span class="badge">最短<br />1分!</span>
		<span class="button">
			{buttonLabel}
			<svg viewBox="0 0 46 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<path d="M2 12h36M28 3l9 9-9 9" />
			</svg>
		</span>
	</div>
</a>

<style>
	.article-bottom-cta {
		--cta-navy: #061a4d;
		--cta-teal: #00958e;
		--cta-line: #bfe4e8;
		--cta-muted: #b8c9cf;
		--cta-yellow: #ffdf35;
		display: grid;
		grid-template-columns: 92px minmax(0, 1fr);
		gap: 0.9rem;
		align-items: center;
		border: 1.5px solid var(--cta-line);
		border-radius: 13px;
		background: #fff;
		box-shadow: 0 4px 16px rgba(6, 27, 44, 0.12);
		margin: 3rem 0;
		padding: 1.2rem 1.25rem;
		position: relative;
		color: inherit;
		text-decoration: none;
		cursor: pointer;
		transition: transform 0.18s ease, box-shadow 0.18s ease;
	}
	.article-bottom-cta:hover {
		text-decoration: none;
		transform: translateY(-1px);
		box-shadow: 0 8px 20px rgba(6, 27, 44, 0.16);
	}
	.article-bottom-cta[hidden] {
		display: none;
	}

	.speed-mark {
		width: 92px;
		height: 92px;
		position: relative;
	}

	.clock {
		width: 86px;
		height: 86px;
		border: 3px solid var(--cta-muted);
		border-radius: 999px;
		background: #f9fdfe;
		display: grid;
		place-items: center;
		position: relative;
	}
	.clock::before {
		content: "";
		width: 21px;
		height: 9px;
		border-radius: 1px;
		background: #5fb5ad;
		position: absolute;
		top: -7px;
		left: 50%;
		transform: translateX(-50%);
	}
	.clock::after {
		content: "";
		position: absolute;
		inset: -8px;
		background:
			linear-gradient(var(--cta-muted), var(--cta-muted)) 50% 0 / 3px 12px no-repeat,
			linear-gradient(var(--cta-muted), var(--cta-muted)) 50% 100% / 3px 12px no-repeat,
			linear-gradient(90deg, var(--cta-muted), var(--cta-muted)) 0 50% / 12px 3px no-repeat,
			linear-gradient(90deg, var(--cta-muted), var(--cta-muted)) 100% 50% / 12px 3px no-repeat;
	}
	.num,
	.unit {
		color: var(--cta-teal);
		font-weight: 800;
		line-height: 1;
		display: block;
		text-align: center;
	}
	.num { font-size: 2.95rem; margin-top: 0.35rem; }
	.unit { font-size: 0.92rem; margin-top: -0.15rem; }

	.spark {
		position: absolute;
		background: #ffd52e;
		border-radius: 999px;
		transform-origin: center;
	}
	.spark-1 { width: 3px; height: 17px; top: -8px; right: 18px; transform: rotate(24deg); }
	.spark-2 { width: 3px; height: 15px; top: 12px; right: 2px; transform: rotate(58deg); }
	.spark-3 { width: 17px; height: 3px; top: 31px; right: -8px; transform: rotate(-9deg); }

	.copy {
		min-width: 0;
	}
	h3 {
		margin: 0;
		color: var(--cta-navy);
		font-size: clamp(1.35rem, 2.4vw, 1.75rem);
		line-height: 1.35;
		letter-spacing: 0;
		font-weight: 800;
	}
	h3 span { display: inline; }
	h3 .lead {
		display: block;
		white-space: nowrap;
	}
	h3 em {
		color: var(--cta-teal);
		font-style: normal;
		white-space: nowrap;
	}
	h3 .result {
		display: block;
	}

	.chips {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
		margin-top: 0.75rem;
	}
	.chips span {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		min-height: 36px;
		padding: 0.35rem 1rem;
		border: 1.5px solid #cddde1;
		border-radius: 999px;
		background: #fff;
		color: var(--cta-navy);
		font-size: 0.95rem;
		font-weight: 700;
		line-height: 1;
		white-space: nowrap;
	}
	.chips i {
		width: 23px;
		height: 23px;
		border: 2.5px solid var(--cta-teal);
		border-radius: 999px;
		position: relative;
		flex: 0 0 auto;
	}
	.chips i::after {
		content: "";
		position: absolute;
		left: 5px;
		top: 5px;
		width: 9px;
		height: 5px;
		border-left: 2.5px solid var(--cta-teal);
		border-bottom: 2.5px solid var(--cta-teal);
		transform: rotate(-45deg);
	}

	.action {
		grid-column: 2;
		justify-self: end;
		position: relative;
		margin-top: 0.3rem;
	}
	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.9rem;
		min-width: 280px;
		min-height: 62px;
		padding: 0.9rem 1.25rem 0.9rem 2.55rem;
		border-radius: 999px;
		background: linear-gradient(135deg, #11afa9 0%, #007e77 100%);
		box-shadow: 0 7px 16px rgba(7, 27, 53, 0.18);
		color: #fff;
		text-decoration: none;
		font-size: 1.12rem;
		font-weight: 800;
		line-height: 1;
		white-space: nowrap;
	}
	.button svg {
		width: 46px;
		height: 24px;
		flex: 0 0 auto;
	}
	.badge {
		position: absolute;
		left: -42px;
		top: 50%;
		transform: translateY(-50%);
		width: 76px;
		height: 76px;
		border-radius: 999px;
		background: var(--cta-yellow);
		color: var(--cta-navy);
		box-shadow: 0 4px 14px rgba(6, 27, 44, 0.15);
		display: grid;
		place-items: center;
		text-align: center;
		font-weight: 800;
		font-size: 1rem;
		line-height: 1.25;
		z-index: 1;
	}

	@media (min-width: 760px) {
		.article-bottom-cta {
			grid-template-columns: 92px minmax(0, 1fr) auto;
		}
		.action {
			grid-column: 3;
			margin-top: 0;
		}
	}

	@media (max-width: 720px) {
		.article-bottom-cta {
			grid-template-columns: 1fr;
			padding: 1rem;
			gap: 0.9rem;
		}
		.speed-mark {
			display: none;
		}
		h3 {
			font-size: 1.35rem;
		}
		.chips span {
			font-size: 0.85rem;
			min-height: 32px;
			padding: 0.3rem 0.75rem;
		}
		.action {
			grid-column: 1;
			justify-self: stretch;
			margin-top: 0.25rem;
		}
		.button {
			width: 100%;
			min-width: 0;
			min-height: 58px;
			padding: 0.85rem 1rem 0.85rem 3.2rem;
			font-size: 1.05rem;
		}
		.badge {
			left: -2px;
			width: 66px;
			height: 66px;
			font-size: 0.86rem;
		}
	}
</style>
