---
import { CTA } from '../consts';
---

<section class="cta">
	<div class="inner">
		<h2>{CTA.heading}</h2>
		<p>{CTA.body}</p>
		<a href={CTA.buttonHref} class="btn">{CTA.buttonLabel}</a>
	</div>
</section>

<style>
	.cta {
		background: linear-gradient(135deg, #1a4d8f 0%, #0f3a6f 100%);
		color: white;
		padding: 2.5rem 1.5rem;
		border-radius: 12px;
		margin: 3rem 0;
		text-align: center;
	}
	h2 {
		color: white;
		margin: 0 0 0.75rem;
		font-size: 1.5rem;
	}
	p {
		color: #cbd5e1;
		margin: 0 0 1.5rem;
		font-size: 1rem;
		line-height: 1.7;
	}
	.btn {
		display: inline-block;
		background: #ef4444;
		color: white;
		padding: 0.875rem 2rem;
		border-radius: 8px;
		font-weight: 700;
		text-decoration: none;
		font-size: 1rem;
		transition: transform 0.15s, background 0.15s;
	}
	.btn:hover {
		background: #dc2626;
		transform: translateY(-2px);
	}
</style>
