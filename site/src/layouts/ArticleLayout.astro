---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import SupervisorBox from '../components/SupervisorBox.astro';
import CTA from '../components/CTA.astro';
import StructuredData from '../components/StructuredData.astro';
import { SITE_URL } from '../consts';

type Props = CollectionEntry<'articles'>['data'] & { slug: string };

const {
	title,
	description,
	category,
	date,
	updatedDate,
	keywords,
	type,
	ogImage,
	slug,
} = Astro.props;

const articleUrl = `${SITE_URL}/articles/${slug}/`;
const breadcrumbs = [
	{ name: 'ホーム', url: '/' },
	{ name: '記事一覧', url: '/articles' },
	{ name: title, url: `/articles/${slug}/` },
];
---

<html lang="ja">
	<head>
		<BaseHead
			title={title}
			description={description}
			image={ogImage}
			type="article"
			publishedTime={date}
			modifiedTime={updatedDate}
			keywords={keywords}
		/>
		<StructuredData
			type="Article"
			title={title}
			description={description}
			url={articleUrl}
			datePublished={date}
			dateModified={updatedDate}
			image={ogImage}
			breadcrumbs={breadcrumbs}
		/>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<nav class="breadcrumb" aria-label="パンくず">
					<a href="/">ホーム</a> <span>/</span>
					<a href="/articles">記事一覧</a> <span>/</span>
					<span>{category}</span>
				</nav>
				<header class="article-header">
					<span class="category-tag">{category}</span>
					<h1>{title}</h1>
					<div class="meta">
						<FormattedDate date={date} />
						{updatedDate && (
							<span class="updated">
								（最終更新：<FormattedDate date={updatedDate} />）
							</span>
						)}
						{type && <span class="type-tag">{type === 'hub' ? 'ハブ記事' : type === 'faculty' ? '学部別' : type === 'exam-format' ? '入試方式別' : ''}</span>}
					</div>
				</header>

				<SupervisorBox variant="short" />

				<div class="prose">
					<slot />
				</div>

				<CTA />
				<SupervisorBox variant="full" />
			</article>
		</main>
		<Footer />

		<style>
			main {
				max-width: 760px;
				margin: 0 auto;
				padding: 1.5rem 1rem 0;
			}
			.breadcrumb {
				font-size: 0.85rem;
				color: #64748b;
				margin-bottom: 1.5rem;
			}
			.breadcrumb a {
				color: #1a4d8f;
				text-decoration: none;
			}
			.breadcrumb a:hover {
				text-decoration: underline;
			}
			.breadcrumb span {
				margin: 0 0.5rem;
			}
			.article-header {
				margin-bottom: 1.5rem;
				border-bottom: 1px solid #e5e7eb;
				padding-bottom: 1.5rem;
			}
			.category-tag {
				display: inline-block;
				background: #eff6ff;
				color: #1a4d8f;
				font-size: 0.8rem;
				font-weight: 600;
				padding: 0.25rem 0.7rem;
				border-radius: 4px;
				margin-bottom: 0.75rem;
			}
			.article-header h1 {
				font-size: 1.875rem;
				line-height: 1.4;
				margin: 0.5rem 0 1rem;
				color: #0f172a;
			}
			.meta {
				font-size: 0.85rem;
				color: #64748b;
				display: flex;
				gap: 0.75rem;
				flex-wrap: wrap;
				align-items: center;
			}
			.updated {
				color: #94a3b8;
			}
			.type-tag {
				background: #f1f5f9;
				padding: 0.15rem 0.5rem;
				border-radius: 3px;
				font-size: 0.75rem;
			}
			.prose {
				font-size: 1rem;
				line-height: 1.85;
				color: #1f2937;
			}
			.prose :global(h2) {
				font-size: 1.5rem;
				margin: 2.5rem 0 1rem;
				padding-top: 0.5rem;
				color: #0f172a;
				border-bottom: 2px solid #1a4d8f;
				padding-bottom: 0.5rem;
			}
			.prose :global(h3) {
				font-size: 1.2rem;
				margin: 2rem 0 0.75rem;
				color: #0f172a;
			}
			.prose :global(h4) {
				font-size: 1.05rem;
				margin: 1.5rem 0 0.5rem;
				color: #1f2937;
			}
			.prose :global(p) {
				margin: 1em 0;
			}
			.prose :global(ul),
			.prose :global(ol) {
				margin: 1em 0;
				padding-left: 1.5em;
			}
			.prose :global(li) {
				margin: 0.4em 0;
			}
			.prose :global(blockquote) {
				border-left: 4px solid #1a4d8f;
				background: #f8fafc;
				padding: 1rem 1.25rem;
				margin: 1.5rem 0;
				border-radius: 0 8px 8px 0;
				color: #334155;
			}
			.prose :global(blockquote p) {
				margin: 0.5em 0;
			}
			.prose :global(blockquote p:first-child) {
				margin-top: 0;
			}
			.prose :global(blockquote p:last-child) {
				margin-bottom: 0;
			}
			.prose :global(table) {
				width: 100%;
				border-collapse: collapse;
				margin: 1.5rem 0;
				font-size: 0.9rem;
			}
			.prose :global(th),
			.prose :global(td) {
				padding: 0.6rem 0.8rem;
				border: 1px solid #e5e7eb;
				text-align: left;
				vertical-align: top;
			}
			.prose :global(th) {
				background: #f8fafc;
				font-weight: 600;
			}
			.prose :global(a) {
				color: #1a4d8f;
				text-decoration: underline;
			}
			.prose :global(a:hover) {
				text-decoration: none;
			}
			.prose :global(code) {
				background: #f1f5f9;
				padding: 0.15em 0.4em;
				border-radius: 3px;
				font-size: 0.9em;
			}
			.prose :global(pre) {
				background: #f8fafc;
				padding: 1rem;
				border-radius: 6px;
				overflow-x: auto;
				border: 1px solid #e5e7eb;
			}
			.prose :global(hr) {
				border: 0;
				border-top: 1px solid #e5e7eb;
				margin: 2.5rem 0;
			}
			@media (max-width: 720px) {
				.article-header h1 {
					font-size: 1.5rem;
				}
			}
		</style>
	</body>
</html>
