---
import type { CollectionEntry } from 'astro:content';
import type { MarkdownHeading } from 'astro';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import SupervisorBox from '../components/SupervisorBox.astro';
import CTA from '../components/CTA.astro';
import CtaBannerInline from '../components/CtaBannerInline.astro';
import StructuredData from '../components/StructuredData.astro';
import TableOfContents from '../components/TableOfContents.astro';
import { SITE_URL } from '../consts';

type Props = CollectionEntry<'articles'>['data'] & {
	slug: string;
	headings?: MarkdownHeading[];
};

const {
	title,
	description,
	category,
	date,
	updatedDate,
	keywords,
	type,
	ogImage,
	slug,
	headings = [],
	showBanner = false,
} = Astro.props;

const articleUrl = `${SITE_URL}/articles/${slug}/`;
const breadcrumbs = [
	{ name: 'ホーム', url: '/' },
	{ name: '記事一覧', url: '/articles' },
	{ name: title, url: `/articles/${slug}/` },
];

// Desktop sidebar TOC items (h2 only, exclude "目次" heading itself)
const tocItems = headings.filter(
	(h) => h.depth === 2 && !/^(目次|もくじ)$/.test(h.text.trim()),
);
---

<html lang="ja">
	<head>
		<BaseHead
			title={title}
			description={description}
			image={ogImage}
			type="article"
			publishedTime={date}
			modifiedTime={updatedDate}
			keywords={keywords}
		/>
		<StructuredData
			type="Article"
			title={title}
			description={description}
			url={articleUrl}
			datePublished={date}
			dateModified={updatedDate}
			image={ogImage}
			breadcrumbs={breadcrumbs}
		/>
	</head>

	<body>
		<Header />

		<div class="page-wrapper">

			<!-- Floating TOC (right side, desktop only, always open) -->
			{tocItems.length >= 1 && (
				<div class="floating-toc" id="floating-toc">
					<div class="toc-panel">
						<div class="toc-panel-header">目次</div>
						<ol class="toc-list">
							{tocItems.map((h, i) => (
								<li>
									<a href={`#${h.slug}`} data-toc-link>
										<span class="toc-num">{String(i + 1).padStart(2, '0')}</span>
										{h.text}
									</a>
								</li>
							))}
						</ol>
					</div>
				</div>
			)}

			<!-- Main article column -->
			<main>
				<article>
					<nav class="breadcrumb" aria-label="パンくず">
						<a href="/">ホーム</a> <span>/</span>
						<a href="/articles">記事一覧</a> <span>/</span>
						<span>{category}</span>
					</nav>
					<header class="article-header">
						<span class="category-tag">{category}</span>
						<h1>{title}</h1>
						<div class="meta">
							<FormattedDate date={date} />
							{updatedDate && (
								<span class="updated">
									（最終更新：<FormattedDate date={updatedDate} />）
								</span>
							)}
							{type && <span class="type-tag">{type === 'hub' ? 'ハブ記事' : type === 'faculty' ? '学部別' : type === 'exam-format' ? '入試方式別' : ''}</span>}
						</div>
					</header>

					<SupervisorBox variant="short" />

					<!-- Mobile TOC (collapsible, hidden at desktop) -->
					<TableOfContents headings={headings} />

					<div class="prose">
						<slot />
					</div>

					<CtaBannerInline />

					<SupervisorBox variant="full" />
					<CTA />
				</article>
			</main>
		</div>

		<Footer />

		<!-- Floating TOC toggle + scroll spy + mid-article CTA injection -->
		<script>
			// Mid-article CTA banner injection
			(function() {
				const prose = document.querySelector('.prose');
				const sourceBanner = document.querySelector('.cta-banner');
				if (!prose || !sourceBanner) return;
				const headings = Array.from(prose.querySelectorAll('h2'));
				if (headings.length < 4) return;
				const midHeading = headings[Math.floor(headings.length / 2)] as HTMLElement;
				const clone = sourceBanner.cloneNode(true) as HTMLElement;
				clone.removeAttribute('aria-label');
				midHeading.parentNode?.insertBefore(clone, midHeading);
			})();

			// Scroll spy
			const links = document.querySelectorAll<HTMLAnchorElement>('[data-toc-link]');
			if (links.length) {
				const headingEls = Array.from(links).map(a => {
					const id = new URL(a.href).hash.slice(1);
					return document.getElementById(id);
				}).filter(Boolean) as HTMLElement[];

				function setActive() {
					const scrollY = window.scrollY + 120;
					let current = headingEls[0];
					for (const el of headingEls) {
						if (el.offsetTop <= scrollY) current = el;
					}
					links.forEach(a => {
						const id = new URL(a.href).hash.slice(1);
						a.classList.toggle('is-active', id === current?.id);
					});
				}
				window.addEventListener('scroll', setActive, { passive: true });
				setActive();
			}
		</script>

		<style>
			/* ── Outer wrapper (single column, full width) ──── */
			.page-wrapper {
				max-width: 820px;
				margin: 0 auto;
				padding: 0 1.25rem;
			}

			/* ── Floating TOC (always open, near article) ───── */
			.floating-toc {
				display: none;
			}
			@media (min-width: 1180px) {
				.floating-toc {
					display: block;
					position: fixed;
					top: 110px;
					/* 記事右端 (50% + 410px) から 16px 離す */
					left: calc(50% + 410px + 16px);
					z-index: 100;
					width: 240px;
				}
			}
			.toc-panel {
				background: #fff;
				border: 1px solid #e5e7eb;
				border-radius: 10px;
				padding: 0.75rem 0.6rem 0.75rem 0.75rem;
				box-shadow: 0 4px 16px rgba(0,0,0,0.06);
				max-height: calc(100vh - 140px);
				overflow-y: auto;
				scrollbar-width: thin;
			}
			.toc-panel-header {
				font-size: 0.72rem;
				font-weight: 700;
				color: #1a4d8f;
				letter-spacing: 0.06em;
				text-transform: uppercase;
				padding: 0 0.5rem 0.5rem;
				margin-bottom: 0.25rem;
				border-bottom: 1px solid #e5e7eb;
			}
			.toc-list {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.toc-list li {
				margin: 0;
			}
			.toc-list a {
				display: flex;
				align-items: baseline;
				gap: 0.45rem;
				padding: 0.38rem 0.5rem;
				color: #475569;
				text-decoration: none;
				line-height: 1.4;
				border-radius: 6px;
				transition: background 0.12s, color 0.12s;
				font-size: 0.82rem;
			}
			.toc-list a:hover,
			.toc-list a.is-active {
				background: #eff6ff;
				color: #1a4d8f;
			}
			.toc-list a.is-active {
				font-weight: 600;
			}
			.toc-num {
				flex-shrink: 0;
				font-size: 0.7rem;
				color: #94a3b8;
				font-weight: 700;
				line-height: 1;
				margin-top: 0.1em;
			}
			.toc-list a.is-active .toc-num {
				color: #1a4d8f;
			}

			/* ── Main article column ────────────────────────── */
			main {
				padding: 1.5rem 0 0;
				min-width: 0;
			}

			/* ── Article content ────────────────────────────── */
			.breadcrumb {
				font-size: 0.85rem;
				color: #64748b;
				margin-bottom: 1.5rem;
			}
			.breadcrumb a {
				color: #1a4d8f;
				text-decoration: none;
			}
			.breadcrumb a:hover { text-decoration: underline; }
			.breadcrumb span { margin: 0 0.5rem; }

			.article-header {
				margin-bottom: 1.5rem;
				border-bottom: 1px solid #e5e7eb;
				padding-bottom: 1.5rem;
			}
			.category-tag {
				display: inline-block;
				background: #eff6ff;
				color: #1a4d8f;
				font-size: 0.8rem;
				font-weight: 600;
				padding: 0.25rem 0.7rem;
				border-radius: 4px;
				margin-bottom: 0.75rem;
			}
			.article-header h1 {
				font-size: 1.875rem;
				line-height: 1.4;
				margin: 0.5rem 0 1rem;
				color: #0f172a;
			}
			.meta {
				font-size: 0.85rem;
				color: #64748b;
				display: flex;
				gap: 0.75rem;
				flex-wrap: wrap;
				align-items: center;
			}
			.updated { color: #94a3b8; }
			.type-tag {
				background: #f1f5f9;
				padding: 0.15rem 0.5rem;
				border-radius: 3px;
				font-size: 0.75rem;
			}

			/* ── Prose styles ───────────────────────────────── */
			.prose {
				font-size: 1.0625rem;
				line-height: 1.85;
				color: #1f2937;
			}

			/* ── CTAバナーが prose 内に JS 挿入された場合のリセット ── */
			.prose :global(.cta-banner) {
				font-size: initial;
				line-height: initial;
			}
			.prose :global(.b-cta),
			.prose :global(.b-cta:hover) {
				color: #fff;
				text-decoration: none;
				line-height: 1;
			}
			.prose :global(p) { margin: 1.1em 0; }
			.prose :global(h2),
			.prose :global(h3),
			.prose :global(h4) {
				scroll-margin-top: 90px;
			}
			.prose :global(h2) {
				font-size: 1.5rem;
				margin: 2.5rem 0 1rem;
				padding-top: 0.5rem;
				color: #0f172a;
				border-bottom: 2px solid #1a4d8f;
				padding-bottom: 0.5rem;
			}
			.prose :global(h3) {
				font-size: 1.2rem;
				margin: 2rem 0 0.75rem;
				color: #0f172a;
			}
			.prose :global(h4) {
				font-size: 1.05rem;
				margin: 1.5rem 0 0.5rem;
				color: #1f2937;
			}
			.prose :global(ul),
			.prose :global(ol) {
				margin: 1em 0;
				padding-left: 1.5em;
			}
			.prose :global(li) { margin: 0.4em 0; }
			.prose :global(blockquote) {
				border-left: 4px solid #1a4d8f;
				background: #eff6ff;
				padding: 1rem 1.25rem;
				margin: 1.5rem 0;
				border-radius: 0 8px 8px 0;
				color: #1f2937;
			}
			.prose :global(blockquote p) { margin: 0.5em 0; }
			.prose :global(blockquote p:first-child) { margin-top: 0; }
			.prose :global(blockquote p:last-child) { margin-bottom: 0; }
			.prose :global(table) {
				width: 100%;
				border-collapse: collapse;
				margin: 1.5rem 0;
				font-size: 0.95rem;
			}
			.prose :global(th),
			.prose :global(td) {
				padding: 0.6rem 0.8rem;
				border: 1px solid #e5e7eb;
				text-align: left;
				vertical-align: top;
			}
			.prose :global(th) {
				background: #f8fafc;
				font-weight: 600;
			}
			.prose :global(a) {
				color: #1a4d8f;
				text-decoration: underline;
			}
			.prose :global(a:hover) { text-decoration: none; }
			.prose :global(code) {
				background: #f1f5f9;
				padding: 0.15em 0.4em;
				border-radius: 3px;
				font-size: 0.9em;
			}
			.prose :global(pre) {
				background: #f8fafc;
				padding: 1rem;
				border-radius: 6px;
				overflow-x: auto;
				border: 1px solid #e5e7eb;
			}
			.prose :global(hr) {
				border: 0;
				border-top: 1px solid #e5e7eb;
				margin: 2.5rem 0;
			}
			.prose :global(details) {
				border: 1px solid #d6dbe3;
				border-radius: 8px;
				margin: 1.25rem 0;
				background: #fafbfc;
				transition: border-color 0.15s;
			}
			.prose :global(details[open]) { border-color: #1a4d8f; }
			.prose :global(summary) {
				cursor: pointer;
				padding: 0.95rem 1.25rem;
				font-weight: 600;
				color: #1a4d8f;
				list-style: none;
				display: flex;
				align-items: center;
				gap: 0.6rem;
				user-select: none;
			}
			.prose :global(summary)::before {
				content: '';
				width: 18px;
				height: 18px;
				flex-shrink: 0;
				background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='%231a4d8f' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'><path d='m9 18 6-6-6-6'/></svg>");
				background-size: contain;
				background-repeat: no-repeat;
				transition: transform 0.2s;
			}
			.prose :global(details[open] > summary)::before { transform: rotate(90deg); }
			.prose :global(summary::-webkit-details-marker) { display: none; }
			.prose :global(details > *:not(summary)) { padding: 0 1.25rem 1.25rem; }

			@media (max-width: 720px) {
				.article-header h1 { font-size: 1.5rem; }
			}
		</style>
	</body>
</html>
