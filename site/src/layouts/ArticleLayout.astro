---
import type { CollectionEntry } from 'astro:content';
import type { MarkdownHeading } from 'astro';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import SupervisorBox from '../components/SupervisorBox.astro';
import RelatedArticles from '../components/RelatedArticles.astro';
import ArticleBottomCtaMain from '../components/ArticleBottomCtaMain.astro';
import StructuredData from '../components/StructuredData.astro';
import { SITE_URL } from '../consts';

type Props = CollectionEntry<'articles'>['data'] & {
	slug: string;
	headings?: MarkdownHeading[];
};

const {
	title,
	description,
	category,
	date,
	updatedDate,
	keywords,
	type,
	ogImage,
	heroImage,
	slug,
	headings = [],
	showBanner = false,
} = Astro.props;

const pageSlug = slug.replace(/\/index$/, '');
const articleUrl = `${SITE_URL}/articles/${pageSlug}/`;
const breadcrumbs = [
	{ name: 'ホーム', url: '/' },
	{ name: '記事一覧', url: '/articles' },
	{ name: title, url: `/articles/${pageSlug}/` },
];

// TOC items: h2 only, exclude "目次" heading itself
const tocItems = headings.filter(
	(h) => h.depth === 2 && !/^(目次|もくじ)$/.test(h.text.trim()),
);
const hasToc = tocItems.length > 0;
// 保護者向け記事はCTA非表示（学生対象CTAのため）
const isParent = slug.startsWith('parent/');
---

<html lang="ja">
	<head>
		<BaseHead
			title={title}
			description={description}
			image={ogImage}
			type="article"
			publishedTime={date}
			modifiedTime={updatedDate}
			keywords={keywords}
		/>
		<StructuredData
			type="Article"
			title={title}
			description={description}
			url={articleUrl}
			datePublished={date}
			dateModified={updatedDate}
			image={ogImage}
			breadcrumbs={breadcrumbs}
		/>
	</head>

	<body>
		<Header />

		<div class="page-wrapper">
			<main>
				<article>
					<nav class="breadcrumb" aria-label="パンくず">
						<a href="/">ホーム</a> <span>/</span>
						<a href="/articles">記事一覧</a> <span>/</span>
						<span>{category}</span>
					</nav>
					{heroImage && (
						<div class="hero-image">
							<img src={heroImage} alt={title} />
						</div>
					)}

					<header class="article-header">
						<span class="category-tag">{category}</span>
						<h1>{title}</h1>
						<div class="meta">
							<FormattedDate date={date} />
							{updatedDate && (
								<span class="updated">
									（最終更新：<FormattedDate date={updatedDate} />）
								</span>
							)}
							{type && <span class="type-tag">{type === 'hub' ? 'ハブ記事' : type === 'faculty' ? '学部別' : type === 'exam-format' ? '入試方式別' : ''}</span>}
						</div>
					</header>

					<SupervisorBox variant="short" />

					<div class="prose">
						<slot />
					</div>

					{!isParent && <ArticleBottomCtaMain variant="mid" sourceOnly />}
					{!isParent && <ArticleBottomCtaMain variant="bottom" />}

					<SupervisorBox variant="full" />
					<RelatedArticles slug={slug} category={category} />
				</article>
			</main>
		</div>

		<!-- Floating TOC button (bottom-right) — list built client-side -->
		<div class="toc-float" id="toc-float" aria-label="目次" style="display:none">
			<button class="toc-fab is-open" id="toc-fab" aria-expanded="true" aria-controls="toc-panel">
				<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
				<span>目次</span>
			</button>
			<div class="toc-panel" id="toc-panel">
				<div class="toc-panel-header">
					<span>目次</span>
					<button class="toc-close" id="toc-close" aria-label="閉じる">
						<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
					</button>
				</div>
				<ol class="toc-panel-list" id="toc-list"></ol>
			</div>
		</div>

		<Footer />

		<!-- Mid-article CTA injection + TOC toggle + scroll spy -->
		<script>
			// Mid-article CTA banner injection
			(function() {
				const prose = document.querySelector('.prose');
				const sourceBanner = document.querySelector<HTMLElement>('.article-bottom-cta[data-mid-source="true"]');
				if (!prose || !sourceBanner) return;

				// 目次・もくじ見出しを除外したh2リスト
				const headings = Array.from(prose.querySelectorAll<HTMLElement>('h2'))
					.filter((h) => !/^(目次|もくじ)$/.test(h.textContent?.trim() ?? ''));

				// H2が4つ未満は挿入しない
				if (headings.length < 4) return;

				function isAllowed(i: number) {
					return i >= 2 && i < headings.length;
				}

				function findIdx(pattern: RegExp): number {
					return headings.findIndex((h, i) =>
						isAllowed(i) && pattern.test(h.textContent?.trim() ?? ''));
				}

				// 初期ターゲットインデックスを決定
				let idx = findIdx(/NG|改善|不合格|落ち|失敗|添削/);
				if (idx === -1) idx = findIdx(/よくある質問|FAQ|まとめ/);
				if (idx === -1) idx = Math.max(2, Math.floor(headings.length * 0.55));

				// 文中CTA後のセクションが2未満なら1つ上の見出しへ移動
				while (idx >= 2 && headings.length - idx - 1 < 2) {
					idx--;
				}

				// index<2 または残り<2 なら挿入しない（記事が短すぎる）
				if (idx < 2 || headings.length - idx - 1 < 2) return;

				const clone = sourceBanner.cloneNode(true) as HTMLElement;
				clone.removeAttribute('data-mid-source');
				clone.removeAttribute('hidden');
				clone.setAttribute('data-ga-label', 'article_mid');
				headings[idx].parentNode?.insertBefore(clone, headings[idx]);
			})();

			// Build TOC list from prose h2 elements (catches both ## and <h2 id="...">)
			(function() {
				const prose = document.querySelector('.prose');
				const tocList = document.getElementById('toc-list');
				const tocFloat = document.getElementById('toc-float') as HTMLElement | null;
				if (!prose || !tocList || !tocFloat) return;

				const h2s = Array.from(prose.querySelectorAll<HTMLElement>('h2[id]'))
					.filter(h => !/^(目次|もくじ)$/.test(h.textContent?.trim() ?? ''));

				if (h2s.length === 0) return;

				// Populate list
				tocList.innerHTML = h2s.map((h, i) =>
					`<li><a href="#${h.id}" data-toc-link>` +
					`<span class="toc-num">${String(i + 1).padStart(2, '0')}</span>` +
					`${h.textContent?.trim() ?? ''}` +
					`</a></li>`
				).join('');

				// Show float container
				tocFloat.style.display = '';

				const fab = document.getElementById('toc-fab');
				const panel = document.getElementById('toc-panel') as HTMLElement | null;
				const closeBtn = document.getElementById('toc-close');

				function openPanel() {
					if (!panel || !fab) return;
					panel.hidden = false;
					fab.setAttribute('aria-expanded', 'true');
					fab.classList.add('is-open');
				}
				function closePanel() {
					if (!panel || !fab) return;
					panel.hidden = true;
					fab.setAttribute('aria-expanded', 'false');
					fab.classList.remove('is-open');
				}

				fab?.addEventListener('click', () => {
					panel?.hidden ? openPanel() : closePanel();
				});
				closeBtn?.addEventListener('click', closePanel);

				document.addEventListener('click', (e) => {
					if (!tocFloat.contains(e.target as Node)) closePanel();
				}, { capture: false });

				// TOC link click: scroll with offset to clear fixed header, keep panel open
				tocList.querySelectorAll<HTMLAnchorElement>('[data-toc-link]').forEach(a => {
					a.addEventListener('click', (e) => {
						e.preventDefault();
						const id = a.getAttribute('href')?.slice(1);
						const target = id ? document.getElementById(id) : null;
						if (target) {
							const offset = 80; // header height + buffer
							const top = target.getBoundingClientRect().top + window.scrollY - offset;
							window.scrollTo({ top, behavior: 'smooth' });
						}
					});
				});

				// Scroll spy
				const links = Array.from(tocList.querySelectorAll<HTMLAnchorElement>('[data-toc-link]'));
				function setActive() {
					const scrollY = window.scrollY + 120;
					let current = h2s[0];
					for (const el of h2s) {
						if (el.offsetTop <= scrollY) current = el;
					}
					links.forEach(a => {
						a.classList.toggle('is-active', a.getAttribute('href') === `#${current?.id}`);
					});
				}
				window.addEventListener('scroll', setActive, { passive: true });
				setActive();

				// Show FAB after 300px scroll
				function updateFabVisibility() {
					tocFloat.classList.toggle('visible', window.scrollY > 300);
				}
				window.addEventListener('scroll', updateFabVisibility, { passive: true });
				updateFabVisibility();
			})();
		</script>

		<style>
			/* ── Page wrapper ───────────────────────────────── */
			.page-wrapper {
				max-width: 820px;
				margin: 0 auto;
				padding: 0 1.25rem;
			}

			/* ── Main article column ────────────────────────── */
			main {
				padding: 1.5rem 0 0;
			}

			/* ── Article content ────────────────────────────── */
			.hero-image {
				width: 100%;
				aspect-ratio: 16 / 9;
				overflow: hidden;
				border-radius: 12px;
				margin-bottom: 1.75rem;
				background: #f1f5f9;
			}
			.hero-image img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				display: block;
			}
			.breadcrumb {
				font-size: 0.85rem;
				color: #64748b;
				margin-bottom: 1.5rem;
			}
			.breadcrumb a {
				color: #1a4d8f;
				text-decoration: none;
			}
			.breadcrumb a:hover { text-decoration: underline; }
			.breadcrumb span { margin: 0 0.5rem; }

			.article-header {
				margin-bottom: 1.5rem;
				border-bottom: 1px solid #e5e7eb;
				padding-bottom: 1.5rem;
			}
			.category-tag {
				display: inline-block;
				background: #eff6ff;
				color: #1a4d8f;
				font-size: 0.8rem;
				font-weight: 600;
				padding: 0.25rem 0.7rem;
				border-radius: 4px;
				margin-bottom: 0.75rem;
			}
			.article-header h1 {
				font-size: 1.875rem;
				line-height: 1.4;
				margin: 0.5rem 0 1rem;
				color: #0f172a;
			}
			.meta {
				font-size: 0.85rem;
				color: #64748b;
				display: flex;
				gap: 0.75rem;
				flex-wrap: wrap;
				align-items: center;
			}
			.updated { color: #94a3b8; }
			.type-tag {
				background: #f1f5f9;
				padding: 0.15rem 0.5rem;
				border-radius: 3px;
				font-size: 0.75rem;
			}

			/* ── Floating TOC ───────────────────────────────── */
			.toc-float {
				position: fixed;
				bottom: 28px;
				right: 24px;
				z-index: 200;
				display: flex;
				flex-direction: column;
				align-items: flex-end;
				gap: 8px;
				opacity: 0;
				pointer-events: none;
				transition: opacity 0.2s;
			}
			.toc-float.visible {
				opacity: 1;
				pointer-events: auto;
			}
			.toc-fab {
				display: flex;
				align-items: center;
				gap: 6px;
				background: #1a4d8f;
				color: #fff;
				border: none;
				border-radius: 24px;
				padding: 10px 18px 10px 14px;
				font-size: 0.875rem;
				font-weight: 700;
				cursor: pointer;
				box-shadow: 0 4px 16px rgba(26,77,143,0.35);
				transition: background 0.15s, transform 0.15s, box-shadow 0.15s;
				white-space: nowrap;
			}
			.toc-fab:hover {
				background: #1e3a6e;
				box-shadow: 0 6px 20px rgba(26,77,143,0.45);
			}
			.toc-fab.is-open {
				background: #334155;
			}
			.toc-panel {
				background: #fff;
				border: 1px solid #e2e8f0;
				border-radius: 14px;
				box-shadow: 0 12px 40px rgba(15,23,42,0.15), 0 2px 8px rgba(15,23,42,0.06);
				width: min(300px, calc(100vw - 48px));
				max-height: 65vh;
				overflow-y: auto;
				scrollbar-width: thin;
				scrollbar-color: #cbd5e1 transparent;
			}
			.toc-panel-header {
				display: flex;
				align-items: center;
				justify-content: space-between;
				padding: 0.7rem 0.875rem 0.6rem 1rem;
				border-bottom: 1px solid #f1f5f9;
				font-weight: 700;
				font-size: 0.75rem;
				color: #64748b;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				position: sticky;
				top: 0;
				background: #fff;
			}
			.toc-close {
				background: none;
				border: none;
				cursor: pointer;
				color: #94a3b8;
				padding: 2px;
				display: flex;
				align-items: center;
				transition: color 0.12s;
			}
			.toc-close:hover { color: #1a4d8f; }
			:global(#toc-list) {
				list-style: none;
				padding: 0.4rem 0 0.6rem;
				margin: 0;
			}
			:global(#toc-list li) { margin: 0; }
			:global(#toc-list a) {
				display: grid;
				grid-template-columns: 28px 1fr;
				align-items: baseline;
				gap: 0;
				padding: 0.45rem 1rem;
				color: #374151;
				text-decoration: none;
				font-size: 0.84rem;
				line-height: 1.5;
				transition: background 0.1s, color 0.1s;
				border-left: 2px solid transparent;
			}
			:global(#toc-list a:hover) {
				background: #f0f7ff;
				color: #1a4d8f;
				border-left-color: #93c5fd;
			}
			:global(#toc-list a.is-active) {
				background: #eff6ff;
				color: #1a4d8f;
				font-weight: 600;
				border-left-color: #1a4d8f;
			}
			:global(#toc-list .toc-num) {
				font-size: 0.68rem;
				color: #cbd5e1;
				font-weight: 700;
				font-variant-numeric: tabular-nums;
				padding-top: 0.1em;
			}
			:global(#toc-list a.is-active .toc-num) {
				color: #93c5fd;
			}

			/* ── Prose styles ───────────────────────────────── */
			.prose {
				font-size: 1.0625rem;
				line-height: 1.85;
				color: #1f2937;
			}

			/* ── CTAバナーが prose 内に JS 挿入された場合のリセット ── */
			.prose :global(.cta-banner) {
				font-size: initial;
				line-height: initial;
			}
			.prose :global(.article-bottom-cta) {
				display: grid !important;
				grid-template-columns: 92px minmax(0, 1fr) auto !important;
				gap: 0.9rem !important;
				align-items: center !important;
				font-size: initial !important;
				line-height: initial !important;
				color: inherit;
				text-decoration: none;
				margin: 2rem 0 !important;
				word-break: normal !important;
				overflow-wrap: normal !important;
			}
			.prose :global(.article-bottom-cta:hover) {
				color: inherit;
				text-decoration: none;
			}
			/* グリッド配置強制 */
			.prose :global(.article-bottom-cta .speed-mark) {
				grid-column: 1 !important;
			}
			.prose :global(.article-bottom-cta .copy) {
				grid-column: 2 !important;
				min-width: 0 !important;
			}
			.prose :global(.article-bottom-cta .action) {
				grid-column: 3 !important;
				justify-self: end !important;
				margin-top: 0 !important;
				position: relative !important;
			}
			@media (max-width: 720px) {
				.prose :global(.article-bottom-cta) {
					grid-template-columns: 1fr !important;
					padding: 1rem !important;
				}
				.prose :global(.article-bottom-cta .speed-mark) {
					display: none !important;
				}
				.prose :global(.article-bottom-cta .copy) {
					grid-column: 1 !important;
				}
				.prose :global(.article-bottom-cta .action) {
					grid-column: 1 !important;
					justify-self: stretch !important;
					margin-top: 0.25rem !important;
				}
			}
			/* h3リセット */
			.prose :global(.article-bottom-cta h3) {
				font-size: clamp(1.35rem, 2.4vw, 1.75rem) !important;
				font-weight: 800 !important;
				line-height: 1.35 !important;
				margin: 0 !important;
				color: #061a4d !important;
				padding: 0 !important;
				border: none !important;
				word-break: keep-all !important;
				overflow-wrap: normal !important;
			}
			.prose :global(.article-bottom-cta h3 .lead),
			.prose :global(.article-bottom-cta h3 .result) {
				display: block !important;
				white-space: nowrap !important;
			}
			.prose :global(.article-bottom-cta h3 em) {
				font-style: normal !important;
				color: #00958e !important;
				white-space: nowrap !important;
			}
			/* chipsリセット */
			.prose :global(.article-bottom-cta .chips) {
				display: flex !important;
				flex-direction: row !important;
				flex-wrap: wrap !important;
				gap: 0.6rem !important;
				margin-top: 0.75rem !important;
				padding: 0 !important;
			}
			.prose :global(.article-bottom-cta .chips span) {
				display: inline-flex !important;
				list-style: none !important;
				margin: 0 !important;
				padding: 0.35rem 1rem !important;
			}
			.prose :global(.article-bottom-cta .chips i) {
				display: block !important;
				flex-shrink: 0 !important;
				list-style: none !important;
			}
			/* ボタンリセット */
			.prose :global(.article-bottom-cta .button) {
				line-height: 1 !important;
				color: #fff !important;
				text-decoration: none !important;
				white-space: nowrap !important;
			}
			.prose :global(.b-cta),
			.prose :global(.b-cta:hover) {
				color: #fff;
				text-decoration: none;
				line-height: 1;
			}
			.prose :global(p) { margin: 1.1em 0; }
			.prose :global(h2) {
				font-size: 1.5rem;
				margin: 2.5rem 0 1rem;
				padding-top: 0.5rem;
				color: #0f172a;
				border-bottom: 2px solid #1a4d8f;
				padding-bottom: 0.5rem;
			}
			.prose :global(h3) {
				font-size: 1.2rem;
				margin: 2rem 0 0.75rem;
				color: #0f172a;
			}
			.prose :global(h4) {
				font-size: 1.05rem;
				margin: 1.5rem 0 0.5rem;
				color: #1f2937;
			}
			.prose :global(ul),
			.prose :global(ol) {
				margin: 1em 0;
				padding-left: 1.5em;
			}
			.prose :global(li) { margin: 0.4em 0; }
			.prose :global(blockquote) {
				border-left: 4px solid #1a4d8f;
				background: #eff6ff;
				padding: 1rem 1.25rem;
				margin: 1.5rem 0;
				border-radius: 0 8px 8px 0;
				color: #1f2937;
			}
			.prose :global(blockquote p) { margin: 0.5em 0; }
			.prose :global(blockquote p:first-child) { margin-top: 0; }
			.prose :global(blockquote p:last-child) { margin-bottom: 0; }
			.prose :global(table) {
				width: 100%;
				border-collapse: collapse;
				margin: 1.5rem 0;
				font-size: 0.95rem;
			}
			.prose :global(th),
			.prose :global(td) {
				padding: 0.6rem 0.8rem;
				border: 1px solid #e5e7eb;
				text-align: left;
				vertical-align: top;
			}
			.prose :global(th) {
				background: #f8fafc;
				font-weight: 600;
			}
			.prose :global(a) {
				color: #1a4d8f;
				text-decoration: underline;
			}
			.prose :global(a:hover) { text-decoration: none; }
			.prose :global(code) {
				background: #f1f5f9;
				padding: 0.15em 0.4em;
				border-radius: 3px;
				font-size: 0.9em;
			}
			.prose :global(pre) {
				background: #f8fafc;
				padding: 1rem;
				border-radius: 6px;
				overflow-x: auto;
				border: 1px solid #e5e7eb;
			}
			.prose :global(hr) {
				border: 0;
				border-top: 1px solid #e5e7eb;
				margin: 2.5rem 0;
			}
			.prose :global(details) {
				border: 1px solid #d6dbe3;
				border-radius: 8px;
				margin: 1.25rem 0;
				background: #fafbfc;
				transition: border-color 0.15s;
			}
			.prose :global(details[open]) { border-color: #1a4d8f; }
			.prose :global(summary) {
				cursor: pointer;
				padding: 0.95rem 1.25rem;
