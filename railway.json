{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "buildCommand": "pip install -r correction-app/backend/requirements.txt && cd site && npm ci && npm run build"
  },
  "deploy": {
    "startCommand": "cd correction-app/backend && uvicorn main:app --host 0.0.0.0 --port $PORT",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
